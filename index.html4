const totalPerguntas = 7;

function irParaSlide(num) {
  document.getElementById('slide-' + slideActual).classList.remove('active');
  slideActual = num;
  document.getElementById('slide-' + num).classList.add('active');
  actualizarProgress(num);
  window.scrollTo({top: 0, behavior: 'smooth'});
}

function actualizarProgress(slide) {
  let pct = 0;
  let texto = '';
  if(slide === 0) { pct = 0; texto = 'Início'; }
  else if(slide >= 1 && slide <= 4) {
    pct = Math.round((slide / 7) * 100);
    texto = 'Pergunta ' + slide + ' de 7';
  }
  else if(slide === 5) { pct = 70; texto = 'Quase pronto!'; }
  else if(slide === 6) { pct = 90; texto = 'A processar...'; }
  else if(slide === 7) { pct = 100; texto = 'Diagnóstico completo!'; }

  document.getElementById('progress-bar').style.width = pct + '%';
  document.getElementById('progress-pct').textContent = pct + '%';
  document.getElementById('progress-text').textContent = texto;
}

function selecionar(pergunta, el, opcao, perfil) {
  // Remove selected de todas as opções desta pergunta
  const opcoes = document.querySelectorAll('#opcoes-' + pergunta + ' .opcao');
  opcoes.forEach(o => o.classList.remove('selected'));

  // Selecciona esta
  el.classList.add('selected');

  // Guarda resposta
  state.respostas[pergunta] = opcao;
  if(pergunta === 2) state.perfil = perfil;

  // Mostra micro-copy
  const mc = document.getElementById('micro-' + pergunta);
  if(mc && microCopies[pergunta] && microCopies[pergunta][opcao]) {
    mc.innerHTML = microCopies[pergunta][opcao];
    mc.classList.add('show');
  }

  // Activa botão
  const btn = document.getElementById('btn-' + pergunta);
  if(btn) btn.classList.add('active');

  // Auto-avança em 1.2s
  setTimeout(() => {
    const btnEl = document.getElementById('btn-' + pergunta);
    if(btnEl && btnEl.classList.contains('active')) {
      btnEl.click();
    }
  }, 1200);
}

async function irParaCaptura() {
  const nome = document.getElementById('campo-nome').value.trim();
  const email = document.getElementById('campo-email').value.trim();
  const btn = document.querySelector('.btn-resultado');

  // Validações visuais
  if(!nome) {
    const el = document.getElementById('campo-nome');
    el.focus();
    el.style.borderColor = '#e63946';
    el.placeholder = '⚠️ Digite seu nome para continuar';
    return;
  }
  if(!email || !email.includes('@') || !email.includes('.')) {
    const el = document.getElementById('campo-email');
    el.focus();
    el.style.borderColor = '#e63946';
    el.placeholder = '⚠️ Email inválido';
    return;
  }

  state.nome = nome;
  state.email = email;

  // Feedback visual no botão
  btn.textContent = '⏳ A processar...';
  btn.style.opacity = '0.8';
  btn.style.pointerEvents = 'none';

  // ── FORMSPREE ──────────────────────────────────────────
  // 1. Vai a formspree.io → Log in/criar conta gratuita
  // 2. New Form → copia o teu endpoint (ex: xrgvqpkb)
  // 3. Substitui FORMSPREE_ID abaixo pelo teu código
  const FORMSPREE_ID = 'xojkyokl'; // Formspree activo ✅

  try {
    if (FORMSPREE_ID !== 'FORMSPREE_ID') {
      // Envia para Formspree
      const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({
          nome: nome,
          email: email,
          perfil: state.perfil || 'nao_identificado',
          fonte: 'Quiz Barriga Chapada',
          data: new Date().toLocaleString('pt-BR')
        })
      });

      if (!res.ok) throw new Error('Formspree falhou');
    }

    // ── FALLBACK: também tenta Hotmart Send / webhook ──
    // Se tiveres um webhook do Make.com ou similar, coloca aqui:
    // await fetch('https://hook.us1.make.com/SEU_WEBHOOK', { method:'POST', ... });

  } catch(err) {
    // Se falhar, continua mesmo assim (não bloqueia o utilizador)
    console.warn('Captura email falhou silenciosamente:', err);
  }

  // Avança para o loading independentemente
  irParaSlide(6);
  iniciarLoading();
}

function iniciarLoading() {
  const bars = ['lb1','lb2','lb3','lb4'];
  const delays = [0, 600, 1200, 1800];
  const widths = [85, 92, 78, 96];

  bars.forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if(el) el.style.cssText = 'width:' + widths[i] + '%;transition:width 0.8s ease;';
    }, delays[i]);
  });

  setTimeout(() => {
    irParaSlide(7);
    mostrarResultado();
    iniciarContador();
    document.getElementById('float-urgencia').classList.add('show');
  }, 3200);
}

function mostrarResultado() {
  const perfilKey = state.perfil || 'inchaco';
  const p = perfis[perfilKey] || perfis.inchaco;

  document.getElementById('perfil-badge').textContent = p.badge;
  document.getElementById('resultado-titulo').innerHTML = p.titulo;
  document.getElementById('resultado-sub').textContent = p.sub;
  document.getElementById('receita-nome').textContent = p.receita;
  document.getElementById('receita-desc').textContent = p.receitaDesc;

  // Personaliza com o nome
  if(state.nome) {
    const sub = document.getElementById('resultado-sub');
    sub.innerHTML = '<strong style="color:var(--verde3)">' + state.nome + '</strong>, ' + p.sub;
  }

  // Anima gauge
  setTimeout(() => {
    const gauge = document.getElementById('gauge-fill');
    gauge.style.width = '78%';
  }, 300);
}

function iniciarContador() {
  let total = 14 * 60 + 59;
  function tick() {
    const m = Math.floor(total/60);
    const s = total % 60;
    const mm = String(m).padStart(2,'0');
    const ss = String(s).padStart(2,'0');
    const rMin = document.getElementById('r-min');
    const rSeg = document.getElementById('r-seg');
    const ft = document.getElementById('float-tempo');
    if(rMin) rMin.textContent = mm;
    if(rSeg) rSeg.textContent = ss;
    if(ft) ft.textContent = mm + ':' + ss;
    if(total > 0) { total--; setTimeout(tick, 1000); }
  }
  tick();
}

// Inicia progress
actualizarProgress(0);

// ===== CARROSSEL =====
(function(){
  const track = document.getElementById('carousel-track');
  if(!track) return;
  const dots = document.querySelectorAll('.carousel-dot');
  const cardW = 280 + 14; // card width + gap

  // Auto-scroll suave
  let autoScroll = setInterval(() => {
    const max = track.scrollWidth - track.clientWidth;
    if(track.scrollLeft >= max - 10) {
      track.scrollTo({left: 0, behavior: 'smooth'});
    } else {
      track.scrollBy({left: cardW, behavior: 'smooth'});
    }
  }, 3000);

  // Atualiza dots
  track.addEventListener('scroll', () => {
    const idx = Math.round(track.scrollLeft / cardW);
    dots.forEach((d,i) => d.classList.toggle('active', i === idx % 4));
  });

  // Drag para arrastar
  let isDown = false, startX, scrollLeft;
  track.addEventListener('mousedown', e => {
    isDown = true;
    track.classList.add('dragging');
    startX = e.pageX - track.offsetLeft;
    scrollLeft = track.scrollLeft;
    clearInterval(autoScroll);
  });
  track.addEventListener('mouseleave', () => { isDown = false; track.classList.remove('dragging'); });
  track.addEventListener('mouseup', () => { isDown = false; track.classList.remove('dragging'); });
  track.addEventListener('mousemove', e => {
    if(!isDown) return;
    e.preventDefault();
    const x = e.pageX - track.offsetLeft;
    track.scrollLeft = scrollLeft - (x - startX) * 1.5;
  });

  // Touch pausa o auto-scroll
  track.addEventListener('touchstart', () => clearInterval(autoScroll), {passive:true});
  track.addEventListener('touchend', () => {
    autoScroll = setInterval(() => {
      const max = track.scrollWidth - track.clientWidth;
      if(track.scrollLeft >= max - 10) {
        track.scrollTo({left: 0, behavior: 'smooth'});
      } else {
        track.scrollBy({left: cardW, behavior: 'smooth'});
      }
    }, 3000);
  }, {passive:true});
})();

</script>
</body>
</html>
